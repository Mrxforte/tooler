rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users — all can read; own doc update; only admin deletes
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Tools — all can read; only admin creates/updates/deletes
    match /tools/{toolId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Objects — all can read; only admin creates/updates/deletes
    match /objects/{objectId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Move requests — all can read and CREATE (to request a move);
    // only admin can update status or delete
    match /move_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Batch move requests — same as move_requests
    match /batch_move_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Brigadier requests — all can read and create; only admin updates/deletes
    match /brigadier_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Notifications — users read/delete their own; only admin creates; admin reads all
    match /notifications/{notificationId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // App settings (admin secret) — all can read; only admin writes
    match /app_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
